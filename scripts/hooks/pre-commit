#!/bin/sh
# Per-agent workstream gate (pre-commit)
#
# Rules:
#   1. Each agent prefix (claude/, gemini/, codex/, devin/, grok/, openai/) gets
#      exactly ONE open PR lane. A second branch from the same agent is blocked
#      until the first PR is merged or closed.
#   2. "Human" branches (no recognised agent prefix) share one lane between them.
#   3. Commits TO a branch that already has an open PR are always allowed.
#   4. gh-pages, master, dev are exempt.
#
# Bypass: SKIP_MONOWORKSTREAM=1 git commit ...

if [ "$SKIP_MONOWORKSTREAM" = "1" ]; then exit 0; fi
if ! command -v gh >/dev/null 2>&1; then
  echo "Warning: gh CLI not found — per-agent workstream gate skipped."
  exit 0
fi

branch=$(git symbolic-ref --short HEAD 2>/dev/null)
[ -z "$branch" ] && exit 0
case "$branch" in gh-pages|master|dev) exit 0 ;; esac

# Derive agent prefix
agent=$(echo "$branch" | cut -d'/' -f1)
case "$agent" in
  claude|gemini|codex|devin|grok|openai) ;;
  *) agent="human" ;;
esac

# Allow if this branch already has an open PR (fixing an existing PR)
branch_pr=$(gh pr list --repo alex-place/lantern-os --state open \
  --json headRefName \
  --jq "map(select(.headRefName == \"$branch\")) | length" 2>/dev/null)
[ "${branch_pr:-0}" -gt 0 ] && exit 0

# Check for a conflicting open PR from the same agent lane
if [ "$agent" = "human" ]; then
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | length' \
    2>/dev/null)
else
  conflict=$(gh pr list --repo alex-place/lantern-os --state open \
    --json headRefName \
    --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | length" \
    2>/dev/null)
fi

if [ "${conflict:-0}" -gt 0 ]; then
  echo ""
  echo "PER-AGENT WORKSTREAM BLOCK: agent '$agent' already has an open PR."
  echo ""
  if [ "$agent" = "human" ]; then
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq '[.[] | select(.headRefName | test("^(claude|gemini|codex|devin|grok|openai)/") | not)] | .[] | "  #\(.number) \(.title) [\(.headRefName)]"' \
      2>/dev/null
  else
    gh pr list --repo alex-place/lantern-os --state open \
      --json number,title,headRefName \
      --jq "[.[] | select(.headRefName | startswith(\"$agent/\"))] | .[] | \"  #\\(.number) \\(.title) [\\(.headRefName)]\"" \
      2>/dev/null
  fi
  echo ""
  echo "Finish or close that PR before opening another lane for '$agent'."
  echo "Bypass: SKIP_MONOWORKSTREAM=1 git commit ..."
  echo ""
  exit 1
fi

exit 0
