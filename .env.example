# Lantern OS — Environment Variables
# Copy to .env and fill in the values you need.
# Keys saved here never leave your machine.

# ── Cloud AI Providers ─────────────────────────────────────────────────────
# Add any key to enable that provider. Providers are tried in order:
# Gemini → Claude → OpenAI → Grok → Ollama (auto mode)

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

XAI_API_KEY=
XAI_MODEL=grok-4.3

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Local Ollama (no API key required) ─────────────────────────────────────
# Start Ollama: ollama serve
# Pull a model: ollama pull qwen2.5-coder
# List models:  ollama list

# Base URL for your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (must be pulled first with: ollama pull <model>)
# Good options: qwen2.5-coder, llama3.1, mistral, phi3, gemma3
OLLAMA_MODEL=qwen2.5-coder

# Set to true to route all completions through Ollama BEFORE trying cloud providers.
# Cloud providers are used as fallback if Ollama is unreachable.
# Leave empty or false to use Ollama only as last resort in auto mode.
OLLAMA_FIRST=false

# ── Discord Bot ────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
LANTERN_DISCORD_GUILD_ID=

# ── Server ─────────────────────────────────────────────────────────────────
# PORT is used when deploying to Railway / cloud (auto-set by the platform)
# PORT=4177
